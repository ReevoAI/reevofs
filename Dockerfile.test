# Stage 1: Build the shim .so
FROM rust:1.93-slim-bookworm AS builder

RUN apt-get update && apt-get install -y \
    pkg-config cmake g++ \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY . .
RUN cargo build --release -p reevofs-preload 2>&1

# Stage 2: Test in the same base image as agentcore
FROM python:3.13.11-slim-trixie

RUN apt-get update && apt-get install -y \
    bash coreutils findutils nodejs \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY --from=builder /app/target/release/libreevofs_preload.so /usr/local/lib/libreevofs_preload.so
COPY tests/ tests/

CMD ["bash", "-c", "\
    python3 tests/mock_api.py 9876 & \
    sleep 1 && \
    REEVOFS_PRELOAD_LIB=/usr/local/lib/libreevofs_preload.so \
    bash tests/integration_test.sh \
"]
